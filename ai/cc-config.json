{
    "default": "#GLOBAL",

    "skills": {
        "cmds":          "~/dotfiles/ai/skills/cmds",
        "fish":          "~/dotfiles/ai/skills/fish",
        "flet":          "~/dotfiles/ai/skills/flet",
        "headscale":     "~/dotfiles/ai/skills/headscale",
        "*fulcrologic":  "~/projects/fulcrologic-claude-settings/skills/*"
    },

    "agents": {
        "*fulcrologic":  "~/projects/fulcrologic-claude-settings/agents/*"
    },

    "commands": {
        "clj-start":        "~/dotfiles/ai/commands/clj-start.md",
        "cc:pending-updates":  "~/dotfiles/ai/commands/pending-updates.md",
        "cc:commit":        "~/dotfiles/ai/commands/commit.md"
    },

    "groups": {
        "#GLOBAL": {
            "skills": ["cmds", "fish"],
            "agents": ["critique", "doc-writer", "optimizer"],
            "commands": ["cc:pending-updates", "cc:commit"]
        },

        "#clojure": {
            "skills": ["#GLOBAL", "clojure", "clojure-repl", "guardrails",
                       "clj-stubs", "deps-upgrade"],
            "agents": ["#GLOBAL", "bdd-tester", "deps-upgrade"],
            "commands": ["clj-start"]
        },

        "#fulcro": {
            "skills": ["#clojure", "fulcro", "fulcro-rad", "fulcro-uism",
                       "fulcro-spec-tdd", "fulcro-i18n", "pathom", "statechart"],
            "agents": ["#clojure", "fulcro-ui-tester", "rad-scaffolder",
                       "statechart-writer", "skill-writer", "agent-writer", "architect"]
        },

        "#datomic": {
            "skills": ["datomic", "seed-data"],
            "agents": []
        },

        "#fulcrologic": {
            "skills": ["#fulcro", "#datomic", "eql-processing",
                       "io-layer-testing", "tufte", "date-time"],
            "agents": ["#fulcro"]
        },

        "#macos": {
            "skills": ["#GLOBAL", "macos-sandboxing"],
            "agents": ["#GLOBAL"]
        },

        "#ALL": "*"
    }
}
