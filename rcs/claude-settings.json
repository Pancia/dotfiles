{
  "env": {
    "SHELL": "/opt/homebrew/bin/fish",
    "CLAUDE_CODE_DISABLE_AUTO_MEMORY": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_SKIP_AUTO_UPDATE": "1"
  },
  "permissions": {
    "allow": [
      "Bash(inbox-fetch-title:*)",
      "Bash(inbox-tags:*)",
      "Bash(cmds path:*)",
      "Bash(cmds describe:*)",
      "Read(~/dotfiles/cmds/*)",
      "Edit(~/dotfiles/cmds/*)",
      "Write(~/dotfiles/cmds/*)",
      "Bash(alt status:*)",
      "Bash(alt help:*)",
      "Bash(alt log:*)",
      "Bash(alt wait:*)",
      "Bash(alt prime:*)",
      "Bash(alt init:*)",
      "Bash(alt mission list:*)",
      "Bash(alt mission show:*)",
      "Bash(alt mission create:*)",
      "Bash(alt message read:*)",
      "Bash(alt message ack:*)",
      "Bash(alt message send:*)",
      "Bash(alt worker list:*)",
      "Bash(alt worker peek:*)",
      "Bash(alt worker inspect:*)",
      "Bash(alt spec create:*)",
      "Bash(alt spec list:*)",
      "Bash(alt spec show:*)",
      "Bash(alt sketch create:*)",
      "Bash(alt sketch list:*)",
      "Bash(alt sketch show:*)",
      "Bash(alt recon:*)",
      "Bash(alt daemon status:*)",
      "Bash(alt daemon logs:*)",
      "Bash(alt workflow list:*)",
      "Bash(alt workflow show:*)",
      "Bash(alt config list:*)",
      "Bash(alt config get:*)",
      "Bash(alt version:*)",
      "Bash(alt session:*)",
      "Bash(alt checkpoint:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git show:*)",
      "Bash(make test:*)",
      "Bash(make lint:*)",
      "Bash(make build:*)",
      "Bash(make install:*)",
      "Bash(ls:*)",
      "Bash(wc:*)",
      "Read(altera/**)",
      "Read(docs/**)",
      "Read(.claude/**)",
      "Read(TODO.md)",
      "Read(CLAUDE.md)",
      "Write(altera/sitrep.md)",
      "Write(altera/sitreps/*)",
      "Write(altera/sketches/*)",
      "Write(altera/specs/*)",
      "Write(altera/missions/*)",
      "Write(altera/worklogs/*)",
      "Write(TODO.md)",
      "Write(docs/**)",
      "Write(bug-reports/**)",
      "Edit(altera/sitrep.md)",
      "Edit(altera/sitreps/*)",
      "Edit(altera/sketches/*)",
      "Edit(altera/missions/*)",
      "Edit(altera/specs/*)",
      "Edit(altera/worklogs/*)",
      "Edit(TODO.md)",
      "Edit(CLAUDE.md)",
      "Edit(docs/**)",
      "Edit(bug-reports/**)"
    ],
    "deny": [
      "mcp__kagi__kagi_summarizer"
    ],
    "additionalDirectories": [
      "~/.claude/plans"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "clj-paren-repair-claude-hook --cljfmt --stats"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/ensure-rcs.sh pre"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/jj-snapshot.sh pre",
            "timeout": 5000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "clj-paren-repair-claude-hook --cljfmt"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/ensure-rcs.sh post"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "printf '{\"hookSpecificOutput\":{\"hookEventName\":\"UserPromptSubmit\",\"additionalContext\":\"[🎲 Character Roll: %d]\"}}' $((RANDOM % 13 + 1))"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "ccsave-hook"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/jj-snapshot.sh stop",
            "timeout": 5000
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "clj-paren-repair-claude-hook --cljfmt"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "claude-statusline"
  },
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true
  },
  "alwaysThinkingEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "cleanupPeriodDays": 365
}
