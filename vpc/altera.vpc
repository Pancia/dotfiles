{
    "space": "current",
    "yabai": {
        "enabled": true,
        "layout": {
            "template": [
                "iterm"
            ]
        }
    },
    "iTerm2": {
        "area": "iterm",
        "dir": "$HOME/projects/altera/",
        "tabs": [
            {"title": "Server", "panes": [
                {"cmd": "@ start", "size": 34, "title": "Start"},
                {"cmd": "@ dashboard", "title": "Status"}
            ]},
            {"title": "Dev", "panes": [
                {"cmd": "@ docs", "title": "Docs"},
                {"cmd": "@ claude", "title": "Claude"}
            ]},
            {"title": "Config", "panes": [
                {"cmd": "vim .claude/settings.local.json ~/dotfiles/vpc/altera.vpc (cmds path)", "size": 40, "title": "Settings"},
                {"cmd": "gs", "title": "Git"}
            ]},
            {"title": "Business", "panes": [
                {"cmd": "@ business", "size": 40, "title": "Business Artifacts"},
                {"cmd": "gs", "title": "Oracle"}
            ]}
        ]
    }
}
