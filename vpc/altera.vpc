{
    "space": "current",
    "yabai": {
        "enabled": true,
        "layout": {
            "template": [
                "iterm"
            ]
        }
    },
    "iTerm2": {
        "area": "iterm",
        "dir": "$HOME/projects/altera/",
        "tabs": [
            {"title": "Server", "panes": [
                {"cmd": "@ start", "size": 47, "title": "Start"},
                {"cmd": "@ log_live", "size": 21, "title": "Logs"},
                {"cmd": "@ status_live", "title": "Status"}
            ]},
            {"title": "Dev", "panes": [
                {"cmd": "@ docs", "title": "Docs"},
                {"cmd": "@ claude", "title": "Claude"}
            ]},
            {"title": "Config", "panes": [
                {"cmd": "vim .claude/settings.local.json", "size": 40, "title": "Settings"},
                {"cmd": "gs", "title": "Git"}
            ]}
        ]
    }
}
