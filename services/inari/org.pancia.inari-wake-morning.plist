<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
    <dict>
        <key>Label</key>
        <string>org.pancia.inari-wake-morning</string>
        <key>ProgramArguments</key>
        <array>
            <string>/usr/bin/caffeinate</string>
            <string>-u</string>
            <string>-t</string>
            <string>120</string>
        </array>
        <key>StartCalendarInterval</key>
        <dict>
            <key>Hour</key>
            <integer>7</integer>
            <key>Minute</key>
            <integer>58</integer>
        </dict>
    </dict>
</plist>
