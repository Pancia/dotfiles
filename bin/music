#!/usr/bin/env ruby

require "cli.rb"

require "json"
require "tempfile"
require "shellwords"
require "pp"

module RbReadline
  require "rb-readline"
  require "readline"
  def self.prefill_prompt(str)
    @rl_prefill = str
    @rl_startup_hook = :rl_prefill_hook
  end
  def self.rl_prefill_hook
    rl_insert_text @rl_prefill if @rl_prefill
    @rl_startup_hook = nil
  end
end

class String
  def colorize(color_code, end_code=0)
    "\e[#{color_code}m#{self}\e[#{end_code}m"
  end
  def reverse() colorize(7, 27) end
end

def hash_diff(x, y)
  Hash[*(x.size > y.size ? x.to_a - y.to_a : y.to_a - x.to_a).flatten(1)]
end

def execute(cmd)
  puts cmd if $options[:dry_run] or $options[:verbose]
  system(cmd) if not $options[:dry_run]
end

Dir["/Users/#{%x[whoami].strip}/dotfiles/lib/ruby/music/*.cmd.rb"]
  .each { |file| require file }

class MusicCMDs extend MusicCMD end

# NOTE: [[~/dotfiles/wiki/zsh_completion.wiki]]
CLI.parse!(MusicCMDs) { |opts|
  opts.separator ""
  opts.separator "Data model:"
  opts.separator "  Songs are JSON objects keyed by UUID in $MUSIC_DB"
  opts.separator "  Audio files live at $MUSIC_DIR/<uuid>.m4a"
  opts.separator "  Song fields: id, artist, name, playlist (album), tags (comma-separated),"
  opts.separator "               url, marked (free-text note), from (source e.g. :ytdl)"
  opts.separator "  Playback via cmus; metadata read/write via ffprobe/ffmpeg"
  opts.separator ""
}
