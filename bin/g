#!/usr/bin/env python3
"""VCS which-key modal menu - single-key navigation for git/jj commands."""
import sys
import os
import tty
import termios
import subprocess

# Detect jj repo (check for .jj/ directory up the tree)
def _is_jj_repo():
    d = os.getcwd()
    while True:
        if os.path.isdir(os.path.join(d, '.jj')):
            return True
        parent = os.path.dirname(d)
        if parent == d:
            return False
        d = parent

IS_JJ = _is_jj_repo()

# Theme detection (macOS light/dark mode)
def _is_dark_mode():
    try:
        subprocess.run(['defaults', 'read', '-g', 'AppleInterfaceStyle'],
                       capture_output=True, check=True)
        return True
    except subprocess.CalledProcessError:
        return False

_dark = _is_dark_mode()

# ANSI colors
BOLD_CYAN = '\033[1;96m'
BOLD_WHITE = '\033[1;37m' if _dark else '\033[1;30m'
BOLD_YELLOW = '\033[1;93m'
YELLOW = '\033[33m'
DIM = '\033[2;37m' if _dark else '\033[2;30m'
RESET = '\033[0m'
CYAN = '\033[36m'
GREEN = '\033[32m'
RED = '\033[31m'
MAGENTA = '\033[35m'


def jj_status_line():
    """Display jj status line."""
    def run(cmd):
        try:
            return subprocess.run(cmd, capture_output=True, text=True, timeout=2).stdout.strip()
        except:
            return ''

    # Get current change and bookmark info
    change_id = run(['jj', 'log', '--no-graph', '-r', '@', '-T', 'change_id.short(8)'])
    if not change_id:
        return

    # Get bookmark (branch) if any
    bookmark = run(['jj', 'log', '--no-graph', '-r', '@', '-T', 'bookmarks'])
    desc = run(['jj', 'log', '--no-graph', '-r', '@', '-T', 'description.first_line()'])

    # Check for changes
    status = run(['jj', 'status'])
    has_changes = 'Working copy changes:' in status
    has_conflict = 'conflict' in status.lower()

    if has_conflict:
        bg = '\033[41m'  # Red
    elif has_changes:
        bg = '\033[43m'  # Yellow
    else:
        bg = '\033[42m'  # Green
    black = '\033[30m'

    parts = [f'jj:{change_id}']
    if bookmark:
        parts.append(bookmark)
    if desc:
        parts.append(desc[:40])

    print(f"{bg}{black} {' '.join(parts)} {RESET}")


def git_status_line():
    """Display git status line matching Tide prompt format."""
    if IS_JJ:
        return jj_status_line()

    def run(cmd):
        try:
            return subprocess.run(cmd, capture_output=True, text=True, timeout=2).stdout.strip()
        except:
            return ''

    # Branch name (or tag/SHA if detached)
    branch = run(['git', 'branch', '--show-current'])
    if not branch:
        # Detached HEAD - try tag, then short SHA
        branch = run(['git', 'describe', '--tags', '--exact-match', 'HEAD'])
        if branch:
            branch = '#' + branch
        else:
            branch = '@' + run(['git', 'rev-parse', '--short', 'HEAD'])
    if not branch or branch in ('@', '#'):
        return  # Not in a git repo

    # Status counts from porcelain
    status = run(['git', 'status', '--porcelain'])
    staged = dirty = untracked = conflicted = 0
    for line in status.splitlines():
        if line.startswith('UU'):
            conflicted += 1
        elif line[0] in 'ADMR':
            staged += 1
        if len(line) > 1 and line[1] in 'ADMR':
            dirty += 1
        if line.startswith('??'):
            untracked += 1

    # Stash count
    stash = len(run(['git', 'stash', 'list']).splitlines()) if run(['git', 'stash', 'list']) else 0

    # Ahead/behind upstream
    ahead = behind = 0
    upstream = run(['git', 'rev-list', '--count', '--left-right', '@{upstream}...HEAD'])
    if upstream and '\t' in upstream:
        behind, ahead = upstream.split('\t')
        behind, ahead = int(behind), int(ahead)

    # Choose background color like Tide: green=clean, yellow=unstable, red=urgent
    if conflicted:
        bg = '\033[41m'  # Red background
    elif staged or dirty or untracked:
        bg = '\033[43m'  # Yellow background
    else:
        bg = '\033[42m'  # Green background
    black = '\033[30m'  # Black text for contrast

    # Build status line - only show non-zero values
    parts = [branch]
    if behind:
        parts.append(f"⇣{behind}")
    if ahead:
        parts.append(f"⇡{ahead}")
    if stash:
        parts.append(f"*{stash}")
    if conflicted:
        parts.append(f"~{conflicted}")
    if staged:
        parts.append(f"+{staged}")
    if dirty:
        parts.append(f"!{dirty}")
    if untracked:
        parts.append(f"?{untracked}")

    print(f"{bg}{black} {' '.join(parts)} {RESET}")

# Chain: run multiple commands sequentially with headers between them
class Chain(tuple):
    """A sequence of shell commands to run with visual headers."""
    pass

def chain(*cmds):
    """Create a chain of commands that display with headers."""
    return Chain(cmds)


# Menu structure - nested dicts are submenus, tuples are (description, command, stay_in_submenu)
# stay_in_submenu=True stays in current submenu, False goes back to root
