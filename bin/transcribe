#!/usr/bin/env fish

set model_path "$HOME/.local/share/whisper-cpp/models/ggml-large-v3-turbo.bin"
set vad_model_path "$HOME/.local/share/whisper-cpp/models/silero-v6.2.0.ggml"

# Parse arguments
set -l no_file false
set -l audio_file

for arg in $argv
    switch $arg
        case --no-file
            set no_file true
        case '--help' '-h'
            echo "Usage: transcribe [--no-file] <audio_file>"
            echo ""
            echo "Transcribe audio/video using whisper-cpp (large-v3-turbo)"
            echo ""
            echo "Options:"
            echo "  --no-file  Don't create transcript file, only print to stdout"
            exit 0
        case '*'
            set audio_file $arg
    end
end

if test -z "$audio_file"
    echo "Usage: transcribe [--no-file] <audio_file>" >&2
    exit 1
end

if not test -f "$audio_file"
    echo "Error: file not found: $audio_file" >&2
    exit 1
end

if not test -f "$model_path"
    echo "Error: model not found: $model_path" >&2
    echo "Download it with:" >&2
    echo "  curl -L -o $model_path https://huggingface.co/ggerganov/whisper.cpp/resolve/main/ggml-large-v3-turbo.bin" >&2
    exit 1
end

# Check if input needs conversion (whisper-cpp only handles wav/mp3/ogg/flac natively)
set -l ext (string lower (string replace -r '.*\.' '' "$audio_file"))
set -l input_file "$audio_file"

if not contains $ext wav mp3 ogg flac
    set -l tmp (mktemp -t transcribe.XXXXXX).wav
    echo "Converting to WAV..." >&2
    ffmpeg -err_detect ignore_err -i "$audio_file" -ar 16000 -ac 1 -c:a pcm_s16le "$tmp" -y -loglevel error
    or begin
        echo "Error: ffmpeg conversion failed" >&2
        exit 1
    end
    set input_file "$tmp"
end

# Transcribe
set -l vad_args
if test -f "$vad_model_path"
    set vad_args --vad --vad-model "$vad_model_path"
end

set -l output (whisper-cli -m "$model_path" -f "$input_file" --no-prints -nt -mc 64 -et 2.0 -lpt -0.3 --suppress-nst $vad_args 2>&1)
set -l status_code $status

# Clean up temp file if we made one
if test "$input_file" != "$audio_file"
    rm -f "$input_file"
end

if test $status_code -ne 0
    echo "Error: whisper-cli failed" >&2
    echo $output >&2
    exit 1
end

# Print to stdout
printf '%s\n' $output

# Write to file unless --no-file
if test "$no_file" = false
    set -l transcript_path "$audio_file.transcript.txt"
    printf '%s\n' $output > "$transcript_path"
    echo "Transcript saved to: $transcript_path" >&2
end
