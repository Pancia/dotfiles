#!/usr/bin/env python3
"""Generate a git commit message from a diff on stdin. Outputs JSON: {"message": "..."}"""

import asyncio
import json
import os
import re
import sys

from claude_agent_sdk import ClaudeSDKClient, ClaudeAgentOptions, ResultMessage

_COMMIT_RE = re.compile(r"<commit>\s*(.*?)\s*</commit>", re.DOTALL)
_INCLUDE_RE = re.compile(r"^@(\S+)\s*$", re.MULTILINE)


def load_template(path: str, _seen: set[str] | None = None) -> str:
    """Read a prompt template, expanding `@<path>` lines as includes.

    An `@<path>` line (alone on its line) is replaced by the contents of the
    referenced file, which is itself expanded recursively. Paths may start
    with `~` and are resolved relative to the including file's directory.
    Cycles raise RuntimeError.
    """
    abs_path = os.path.abspath(os.path.expanduser(path))
    seen = _seen if _seen is not None else set()
    if abs_path in seen:
        raise RuntimeError(f"include cycle detected at {abs_path}")
    seen = seen | {abs_path}
    base = os.path.dirname(abs_path)
    with open(abs_path) as f:
        text = f.read()

    def _replace(match: re.Match) -> str:
        ref = os.path.expanduser(match.group(1))
        if not os.path.isabs(ref):
            ref = os.path.join(base, ref)
        return load_template(ref, seen)

    return _INCLUDE_RE.sub(_replace, text)


def extract_commit(text: str) -> str:
    """Extract commit message from <commit> tags."""
    m = _COMMIT_RE.search(text)
    return m.group(1) if m else text.strip()


async def generate(system_prompt: str, diff: str) -> str:
    options = ClaudeAgentOptions(
        model="claude-sonnet-4-6",
        system_prompt=system_prompt,
        allowed_tools=[],
        permission_mode="default",
    )
    client = ClaudeSDKClient(options=options)
    async with client:
        await client.query(diff)
        async for msg in client.receive_response():
            if isinstance(msg, ResultMessage):
                return extract_commit(msg.result)
    return ""


def main():
    diff = sys.stdin.read()
    if not diff.strip():
        print('{"message": ""}')
        return

    system_path = sys.argv[1] if len(sys.argv) > 1 else None
    if system_path:
        system_prompt = load_template(system_path)
    else:
        system_prompt = "You are a git commit message writer. Output ONLY the commit message, nothing else."

    message = asyncio.run(generate(system_prompt, diff))
    json.dump({"message": message}, sys.stdout)
    print()


if __name__ == "__main__":
    main()
