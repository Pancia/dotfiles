#!/usr/bin/env -S uv run --with requests --with beautifulsoup4 python3
"""
Crawl a website and list all internal pages.

Usage:
    crawl-sitemap <url> [--depth N] [--verbose]

Starts from the given URL, recursively follows internal links,
and outputs a deduplicated list of all discovered pages.
"""

import sys
import argparse
from urllib.parse import urljoin, urlparse, urldefrag

import requests
from bs4 import BeautifulSoup


def normalize_url(url):
    """Strip fragment, trailing slash, normalize to consistent form."""
    url, _ = urldefrag(url)
    if url.endswith('/') and url.count('/') > 3:
        url = url.rstrip('/')
    return url


def is_internal(url, base_domain):
    parsed = urlparse(url)
    return parsed.netloc == '' or parsed.netloc == base_domain


def extract_links(html, base_url):
    soup = BeautifulSoup(html, 'html.parser')
    links = set()
    for tag in soup.find_all('a', href=True):
        href = tag['href']
        full = urljoin(base_url, href)
        links.add(normalize_url(full))
    return links


def crawl(base_url, max_depth=5, verbose=False):
    parsed = urlparse(base_url)
    base_domain = parsed.netloc
    base_scheme = parsed.scheme

    visited = set()
    queue = [(normalize_url(base_url), 0)]
    pages = []

    while queue:
        url, depth = queue.pop(0)

        if url in visited or depth > max_depth:
            continue

        parsed_url = urlparse(url)
        if not is_internal(url, base_domain):
            continue

        # skip non-page resources
        path = parsed_url.path.lower()
        skip_exts = ('.css', '.js', '.png', '.jpg', '.jpeg', '.gif', '.svg',
                     '.ico', '.woff', '.woff2', '.ttf', '.eot', '.pdf',
                     '.zip', '.tar', '.gz', '.mp3', '.mp4', '.webp')
        if any(path.endswith(ext) for ext in skip_exts):
            continue

        visited.add(url)

        try:
            resp = requests.get(url, timeout=10, headers={
                'User-Agent': 'crawl-sitemap/1.0'
            })
            content_type = resp.headers.get('content-type', '')
            if 'text/html' not in content_type:
                continue
            resp.raise_for_status()
        except (requests.RequestException, Exception) as e:
            if verbose:
                print(f"  SKIP {url} ({e})", file=sys.stderr)
            continue

        pages.append(url)
        if verbose:
            print(f"  [{depth}] {url}", file=sys.stderr)

        for link in extract_links(resp.text, url):
            if link not in visited:
                queue.append((link, depth + 1))

    return sorted(pages)


def main():
    parser = argparse.ArgumentParser(description='Crawl a website and list all internal pages.')
    parser.add_argument('url', help='Base URL to crawl')
    parser.add_argument('--depth', type=int, default=5, help='Max crawl depth (default: 5)')
    parser.add_argument('--verbose', '-v', action='store_true', help='Show progress on stderr')
    args = parser.parse_args()

    url = args.url
    if not url.startswith('http'):
        url = 'https://' + url

    pages = crawl(url, max_depth=args.depth, verbose=args.verbose)

    for page in pages:
        print(page)

    if args.verbose:
        print(f"\n  {len(pages)} pages found", file=sys.stderr)


if __name__ == '__main__':
    main()
