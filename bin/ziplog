#!/bin/bash

cd ~/.local/share/monitor/ || exit 1

# Interactive confirmation unless --yes is passed
if [ "$1" != "--yes" ]; then
    ls -lh
    echo "GO AHEAD? OR CTRL-C"
    read empty
fi
find . -name "*.log.json" -type f -mtime +6d | while read -r file; do
    if [ ! -f "${file}.zip" ]; then
        echo "Zipping $file..."
        zip --move -9 "${file}.zip" "$file"
    else
        echo "Zip file already exists for $file, skipping..."
    fi
done

# Archive completed months into archive/YYYY_MM.zip
# The cutoff month is: if day >= 8, include previous month; otherwise, two months ago
if [ "$(date +%d)" -ge 8 ]; then
    cutoff=$(date -v-1m +%Y_%m)
else
    cutoff=$(date -v-2m +%Y_%m)
fi
mkdir -p archive
# Find all YYYY_MM prefixes present, archive any <= cutoff
for month in $(ls -1 | grep -oE '^[0-9]{4}_[0-9]{2}' | sort -u); do
    if [[ "$month" < "$cutoff" || "$month" == "$cutoff" ]]; then
        echo "Archiving $month..."
        zip -9 "archive/${month}.zip" ${month}_*
        rm ${month}_*
        echo "Archived to archive/${month}.zip"
    fi
done

# Backup to cloud
BACKUP_DIR="$HOME/Cloud/_inbox/monitor/minimac/"
mkdir -p "$BACKUP_DIR"
echo "Syncing to $BACKUP_DIR..."
rsync -av ~/.local/share/monitor/ "$BACKUP_DIR"

ls -lh
echo "log size"
du -ha ~/.local/share/monitor/ | sort -h
