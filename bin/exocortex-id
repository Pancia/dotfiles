#!/usr/bin/env python3
"""
# Copyright (c) 2026 George Lipov. All rights reserved.
# Licensed under the MIT License.

Generate compact timestamp-based IDs for an exocortex/zettelkasten.

Encodes the current UTC date and time into a short, chronologically sortable
string using base-36. Typical output: "2649-1oeb" (~8-9 chars).

Format:  [prefix] YY M D [separator] H TTT [suffix]

  YY  — 2-digit year (or years-since-1970 in base-36 with --unix-time)
  M   — month in base-36 (1-9, a=Oct, b=Nov, c=Dec)
  D   — day in base-36 (1-9, a=10, ..., v=31)
  H   — UTC hour in base-36 (0-n)
  TTT — fractional hour in base-36, using full 36^n range (-t controls digits)

Usage:
  exocortex-id                        # default: "2649-1oeb" (3 time digits)
  exocortex-id -t 4                   # "2649-1oeb0" (4 time digits, ~2ms)
  exocortex-id -t 5                   # "2649-1oeb00" (5 time digits, ~60µs)
  exocortex-id --prefix "."           # ".2649-1oeb"
  exocortex-id --decimal-date         # "260409-1oeb"
  exocortex-id --unix-time            # "1k49-1oeb"
  exocortex-id --parse 2649-1oeb      # parse back to datetime
"""

import argparse
from datetime import datetime, timezone


BASE36_CHARS = "0123456789abcdefghijklmnopqrstuvwxyz"
DEFAULT_TIME_DIGITS = 3


def to_base36(n: int) -> str:
    """Convert a non-negative integer to a base-36 string."""
    if n < 0:
        raise ValueError("Negative numbers not supported")
    if n == 0:
        return "0"
    digits = []
    while n:
        digits.append(BASE36_CHARS[n % 36])
        n //= 36
    return "".join(reversed(digits))


def from_base36(s: str) -> int:
    """Convert a base-36 string to an integer."""
    return int(s, 36)


def generate_id(
    *,
    unix_time_base36: bool = False,
    decimal_date: bool = False,
    separator: str = "-",
    prefix: str = "",
    suffix: str = "",
    time_digits: int = DEFAULT_TIME_DIGITS,
    now: datetime | None = None,
) -> str:
    """Generate an exocortex ID from the given or current UTC time."""
    if now is None:
        now = datetime.now(timezone.utc)

    year = now.year
    month = now.month
    day = now.day

    if unix_time_base36:
        yy = to_base36(year - 1970).zfill(2)
        m = to_base36(month)
        d = to_base36(day)
    else:
        yy = str(year)[2:]
        if decimal_date:
            m = str(month).zfill(2)
            d = str(day).zfill(2)
        else:
            m = to_base36(month)
            d = to_base36(day)

    h = to_base36(now.hour)

    # Approach B: use full 36^n range for maximum precision per digit
    total_seconds = now.minute * 60 + now.second + now.microsecond / 1_000_000
    fraction_of_hour = total_seconds / 3600
    time_value = int(fraction_of_hour * (36 ** time_digits))
    ttt = to_base36(time_value).zfill(time_digits)

    return f"{prefix}{yy}{m}{d}{separator}{h}{ttt}{suffix}"


def parse_id(
    id_str: str,
    *,
    unix_time_base36: bool = False,
    decimal_date: bool = False,
    separator: str = "-",
    prefix: str = "",
    suffix: str = "",
    time_digits: int | None = None,
) -> datetime:
    """Parse an exocortex ID back into a UTC datetime.

    time_digits is auto-detected from the length of the time portion
    (everything after the separator minus 1 for the hour char).
    Pass explicitly only if you need to override.
    """
    # Strip prefix and suffix
    s = id_str
    if prefix and s.startswith(prefix):
        s = s[len(prefix):]
    if suffix and s.endswith(suffix):
        s = s[:-len(suffix)]

    # Split on separator into date and time parts
    parts = s.split(separator, 1)
    if len(parts) != 2:
        raise ValueError(f"Expected separator '{separator}' in ID: {id_str}")
    date_part, time_part = parts

    # Parse date
    if unix_time_base36:
        yy_str = date_part[:2]
        rest = date_part[2:]
        year = 1970 + from_base36(yy_str)
        month = from_base36(rest[0])
        day = from_base36(rest[1:])
    elif decimal_date:
        year = 2000 + int(date_part[:2])
        month = int(date_part[2:4])
        day = int(date_part[4:6])
    else:
        year = 2000 + int(date_part[:2])
        month = from_base36(date_part[2])
        day = from_base36(date_part[3:])

    # Parse time: H (1 char) + time digits (auto-detected from length)
    hour = from_base36(time_part[0])
    ttt_str = time_part[1:]
    if time_digits is None:
        time_digits = len(ttt_str)
    ttt = from_base36(ttt_str)

    # Reverse the fractional hour encoding
    fraction_of_hour = ttt / (36 ** time_digits)
    total_seconds = fraction_of_hour * 3600
    minute = int(total_seconds // 60)
    second_frac = total_seconds - minute * 60
    second = int(second_frac)
    microsecond = int((second_frac - second) * 1_000_000)

    return datetime(year, month, day, hour, minute, second, microsecond,
                    tzinfo=timezone.utc)


def main(argv: list[str] | None = None) -> None:
    parser = argparse.ArgumentParser(
        description="Generate compact timestamp-based exocortex IDs."
    )
    parser.add_argument("--unix-time", action="store_true",
                        help="Encode year as years-since-1970 in base-36")
    parser.add_argument("--decimal-date", action="store_true",
                        help="Use zero-padded decimal month/day")
    parser.add_argument("--separator", default="-",
                        help="Separator between date and time (default: -)")
    parser.add_argument("--prefix", default="",
                        help="String to prepend to the ID")
    parser.add_argument("--suffix", default="",
                        help="String to append to the ID")
    parser.add_argument("-t", "--time-digits", type=int,
                        default=DEFAULT_TIME_DIGITS,
                        help="Number of base-36 time digits (default: 3, "
                             "precision: 3=~77ms, 4=~2ms, 5=~60µs)")
    parser.add_argument("--parse", metavar="ID",
                        help="Parse an ID back to a UTC datetime")
    parser.add_argument("--local", action="store_true",
                        help="Display parsed time in local timezone instead of UTC")
    args = parser.parse_args(argv)

    if args.parse:
        dt = parse_id(
            args.parse,
            unix_time_base36=args.unix_time,
            decimal_date=args.decimal_date,
            separator=args.separator,
            prefix=args.prefix,
            suffix=args.suffix,
        )
        if args.local:
            dt = dt.astimezone()
            print(dt.strftime("%Y-%m-%d %H:%M:%S.%f %Z"))
        else:
            print(dt.strftime("%Y-%m-%d %H:%M:%S.%f UTC"))
    else:
        print(generate_id(
            unix_time_base36=args.unix_time,
            decimal_date=args.decimal_date,
            separator=args.separator,
            prefix=args.prefix,
            suffix=args.suffix,
            time_digits=args.time_digits,
        ))


if __name__ == "__main__":
    main()
