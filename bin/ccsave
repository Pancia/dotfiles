#!/usr/bin/env bash
# Save current Claude Code session to .cc/sessions.json
# Usage: ccsave [title]
set -euo pipefail

if [ -z "${CLAUDE_SESSION_ID:-}" ]; then
    echo "Not inside a Claude Code session (no CLAUDE_SESSION_ID)" >&2
    exit 1
fi

id="$CLAUDE_SESSION_ID"
title="${*}"
timestamp=$(date '+%Y-%m-%d %H:%M')
dir="$(pwd)/.cc"
file="$dir/sessions.json"

mkdir -p "$dir"

# Build new entry
new_entry=$(jq -cn --arg id "$id" --arg ts "$timestamp" --arg title "$title" \
    '{id: $id, ts: $ts, title: $title}')

# Read existing array, remove dupe, append
if [ -f "$file" ]; then
    jq -c --arg id "$id" --argjson entry "$new_entry" \
        '[.[] | select(.id != $id)] + [$entry]' "$file" > "$file.tmp"
    mv "$file.tmp" "$file"
else
    printf '%s\n' "[$new_entry]" > "$file"
fi

# Back up session JSONL
project_dir=$(echo "$(pwd)" | tr '/' '-')
jsonl="$HOME/.claude/projects/$project_dir/$id.jsonl"
if [ -f "$jsonl" ]; then
    backup_dir="$(pwd)/.cc/session-backups"
    mkdir -p "$backup_dir"
    zstd -qf "$jsonl" -o "$backup_dir/$id.jsonl.zst"
fi

if [ -n "$title" ]; then
    echo "Saved session: $id ($timestamp — $title)"
else
    echo "Saved session: $id ($timestamp)"
    # Auto-generate title using fish ccs function
    fish -c "ccs autotitle --yes $id"
fi
