#!/usr/bin/env bash
# Save current Claude Code session to .claude-sessions
# Usage: ccsave [title]
set -euo pipefail

if [ -z "${CLAUDE_SESSION_ID:-}" ]; then
    echo "Not inside a Claude Code session (no CLAUDE_SESSION_ID)" >&2
    exit 1
fi

id="$CLAUDE_SESSION_ID"
title="${*}"
timestamp=$(date '+%Y-%m-%d %H:%M')
file="$(pwd)/.claude-sessions"

# Dedup by id (JSONL format, one JSON object per line)
if [ -f "$file" ]; then
    jq -c "select(.id != \"$id\")" "$file" > "$file.tmp" 2>/dev/null || true
    mv "$file.tmp" "$file"
fi

# Append new entry as JSON
jq -cn --arg id "$id" --arg ts "$timestamp" --arg title "$title" \
    '{id: $id, ts: $ts, title: $title}' >> "$file"

if [ -n "$title" ]; then
    echo "Saved session: $id ($timestamp — $title)"
else
    echo "Saved session: $id ($timestamp)"
    # Auto-generate title using fish ccs function
    fish -c "ccs autotitle --yes $id"
fi
